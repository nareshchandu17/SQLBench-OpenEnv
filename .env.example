# SQLBench-OpenEnv Configuration
# Copy this to .env and fill in your actual API keys

# API Endpoint (OpenRouter for these models)
API_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Option 1: Separate API Keys (Recommended)
# ============================================
# Use separate keys per model to avoid rate limits and run stable benchmarks
# This approach allows parallel execution and better load distribution

LLAMA_API_KEY=sk-or-v1-your-llama-key-here
DOLPHIN_API_KEY=sk-or-v1-your-dolphin-key-here
GEMMA_API_KEY=sk-or-v1-your-gemma-key-here

# ============================================
# Option 2: Single Shared Key (Fallback)
# ============================================
# If no model-specific key is set, falls back to OPENROUTER_API_KEY
# Useful for testing or when using the same provider for all models

OPENROUTER_API_KEY=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

# ============================================
# Option 3: HuggingFace (Alternative)
# ============================================
# For HF models, use HF_TOKEN and set API_BASE_URL to HF endpoint
# HF_TOKEN=hf_your_hf_token_here

# OPENROUTER_API_KEY=your_shared_openrouter_key_here

# ============================================
# Baseline Configuration (single model)
# ============================================
# Choose which model to use for the baseline test
# Valid options:
#   meta-llama/llama-3.3-70b-instruct
#   cognitivecomputations/dolphin-mistral-24b-venice-edition:free
#   google/gemma-2-27b-it

# MODEL_NAME=meta-llama/llama-3.3-70b-instruct
# LLAMA_API_KEY=your_key_here

# ============================================
# Benchmark Modes
# ============================================
# BENCHMARK_MODE=0  : Fast baseline (default)
# BENCHMARK_MODE=1  : Full multi-model benchmark

# BENCHMARK_MODE=0

# ============================================
# Model Information
# ============================================
# Llama 3.3 70B - Meta's latest large language model
# Dolphin Mistral 24B - Cognitive Computations' fine-tuned 24B variant
# Gemma 27B - Google's open-source 27B instruction-tuned model
# 
# All models accessed via OpenRouter for consistency

