# SQLBench-OpenEnv Configuration
# Copy this to .env and fill in your actual API key

# OpenRouter API Configuration
# Single API key for all models (gateway pattern)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Models using this key:
# - Llama 3.3 70B (meta-llama/llama-3.3-70b-instruct)
# - Dolphin Mistral 24B (cognitivecomputations/dolphin-mistral-24b-venice-edition:free)
# - Gemma 27B (google/gemma-2-27b-it)

# Get your API key from: https://openrouter.ai/keys

